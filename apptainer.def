Bootstrap: docker
From: gitlab-registry.cern.ch/adaptyst/gentoo-fp:latest

%files
    {{ project_dir }} adaptyst

%post
    emerge --quiet-build=y dev-build/ninja dev-cpp/cli11 dev-cpp/nlohmann_json dev-libs/boost app-arch/libarchive dev-libs/poco
    cd adaptyst
    mkdir build && cd build
    cmake .. -G Ninja
    cmake --build .
    cmake --install .
    cd ../.. && rm -rf adaptyst
    ldconfig